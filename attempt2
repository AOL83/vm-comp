<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
  <title>Surgeon‑Level PC Inspector – Transparent Case, Circuit Detail, Code Correlation</title>
  <style>
    body {
      margin: 0;
      overflow: hidden;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: #0a0a14;
    }
    /* ---- Navbar ---- */
    #navbar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      background: rgba(10, 10, 20, 0.92);
      backdrop-filter: blur(12px);
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
      padding: 0.7rem 1.5rem;
      z-index: 30;
      border-bottom: 1px solid rgba(255,255,255,0.12);
    }
    .nav-group {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      color: #ccc;
      font-size: 0.9rem;
    }
    .nav-btn {
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.3);
      color: #ddd;
      padding: 0.4rem 1.2rem;
      border-radius: 20px;
      cursor: pointer;
      transition: 0.2s;
      font-weight: 500;
    }
    .nav-btn.active {
      background: #4a90e2;
      border-color: #4a90e2;
      color: white;
    }
    input[type=range] {
      width: 100px;
    }
    /* ---- Inspection Panel (right side) ---- */
    #inspect-panel {
      position: fixed;
      right: 20px;
      top: 120px;
      width: 360px;
      max-height: 70vh;
      background: rgba(15, 15, 30, 0.95);
      backdrop-filter: blur(15px);
      border: 1px solid rgba(255,255,255,0.25);
      border-radius: 20px;
      padding: 20px;
      color: #ddd;
      font-size: 0.9rem;
      z-index: 25;
      display: none;
      flex-direction: column;
      gap: 15px;
      box-shadow: 0 20px 40px rgba(0,0,0,0.7);
      overflow-y: auto;
    }
    #inspect-panel h2 {
      margin: 0;
      color: #8ab4f8;
    }
    canvas.block-diagram {
      width: 100%;
      height: 140px;
      background: #1a1a2e;
      border-radius: 8px;
    }
    .code-snippet {
      background: #111122;
      border-radius: 8px;
      padding: 10px;
      font-family: 'Courier New', monospace;
      font-size: 0.8rem;
      white-space: pre-wrap;
    }
    .highlight {
      background: #4a90e2;
      color: white;
      padding: 0 4px;
      border-radius: 3px;
    }
    button {
      background: #4a90e2;
      border: none;
      color: white;
      padding: 8px 16px;
      border-radius: 6px;
      font-weight: 600;
      cursor: pointer;
      transition: 0.2s;
    }
    button:hover {
      background: #6aa8ff;
    }
    #close-panel {
      align-self: flex-end;
      background: transparent;
      border: 1px solid #aaa;
      color: #aaa;
      padding: 4px 10px;
    }
    #info-hint {
      position: fixed;
      bottom: 25px;
      left: 25px;
      color: #aaa;
      background: rgba(0,0,0,0.6);
      padding: 6px 14px;
      border-radius: 8px;
      z-index: 20;
      font-size: 0.85rem;
    }
  </style>
</head>
<body>
  <div id="navbar">
    <div class="nav-group">
      <span>🔍 Case</span>
      <input type="range" id="opacity-slider" min="0" max="100" value="90" step="1">
      <span id="opacity-val">90%</span>
    </div>
    <div class="nav-group">
      <button id="clip-toggle" class="nav-btn">🧠 Clip Plane OFF</button>
      <input type="range" id="clip-slider" min="-1.5" max="1.5" value="0" step="0.01" disabled>
    </div>
    <div class="nav-group">
      <button id="reset-view" class="nav-btn">↺ Reset View</button>
    </div>
  </div>

  <div id="inspect-panel">
    <button id="close-panel">✕ Close</button>
    <h2 id="part-name">Component</h2>
    <canvas id="block-diagram" class="block-diagram" width="320" height="140"></canvas>
    <div><strong>Code Interaction:</strong></div>
    <div id="code-snippet" class="code-snippet">; select a component</div>
    <button id="simulate-btn">▶ Simulate Data Flow</button>
  </div>

  <div id="info-hint">🖱️ Click on a component (CPU, GPU, RAM, Chipset) to inspect</div>

  <script type="importmap">
    {
      "imports": {
        "three": "https://unpkg.com/three@0.152.0/build/three.module.js",
        "three/addons/": "https://unpkg.com/three@0.152.0/examples/jsm/"
      }
    }
  </script>

  <script type="module">
    import * as THREE from 'three';
    import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
    import { CSS2DRenderer, CSS2DObject } from 'three/addons/renderers/CSS2DRenderer.js';

    // -------------------- SCENE --------------------
    const scene = new THREE.Scene();
    scene.background = new THREE.Color(0x0a0a14);
    scene.fog = new THREE.Fog(0x0a0a14, 5, 25);

    const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.5, 50);
    camera.position.set(5, 3.5, 7);
    camera.lookAt(0, 0.2, 0);

    const renderer = new THREE.WebGLRenderer({ antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.shadowMap.enabled = true;
    renderer.shadowMap.type = THREE.PCFSoftShadowMap;
    renderer.localClippingEnabled = true; // critical for clipping
    document.body.appendChild(renderer.domElement);

    const labelRenderer = new CSS2DRenderer();
    labelRenderer.setSize(window.innerWidth, window.innerHeight);
    labelRenderer.domElement.style.position = 'absolute';
    labelRenderer.domElement.style.top = '0';
    labelRenderer.domElement.style.pointerEvents = 'none';
    document.body.appendChild(labelRenderer.domElement);

    const controls = new OrbitControls(camera, renderer.domElement);
    controls.enableDamping = true;
    controls.dampingFactor = 0.05;
    controls.target.set(0, 0.15, 0);
    controls.update();

    // Lights
    scene.add(new THREE.AmbientLight(0x404066));
    const dirLight = new THREE.DirectionalLight(0xffffff, 1.2);
    dirLight.position.set(5, 8, 5);
    dirLight.castShadow = true;
    dirLight.receiveShadow = true;
    dirLight.shadow.mapSize.width = 1024;
    dirLight.shadow.mapSize.height = 1024;
    dirLight.shadow.camera.near = 1;
    dirLight.shadow.camera.far = 30;
    scene.add(dirLight);
    scene.add(new THREE.PointLight(0x335577, 0.8));

    // ---- Materials (with clipping enabled) ----
    const clippingPlane = new THREE.Plane(new THREE.Vector3(0, 0, -1), 0); // initial Z=0
    const clipPlanes = [clippingPlane];

    function createClippedMaterial(color, opts = {}) {
      return new THREE.MeshStandardMaterial({
        color,
        roughness: opts.roughness !== undefined ? opts.roughness : 0.5,
        metalness: opts.metalness !== undefined ? opts.metalness : 0.3,
        clippingPlanes: clipPlanes,
        clipShadows: true,
        ...opts
      });
    }

    // ---- GROUPS ----
    const skinGroup = new THREE.Group();
    const boardGroup = new THREE.Group();
    const componentsGroup = new THREE.Group();
    scene.add(skinGroup, boardGroup, componentsGroup);

    // ---- CASE (SKIN) with transparent material ----
    const caseMat = new THREE.MeshStandardMaterial({
      color: 0x3a3a4a,
      roughness: 0.2,
      metalness: 0.8,
      transparent: true,
      opacity: 0.9,
      clippingPlanes: clipPlanes,
      clipShadows: true,
    });
    const sideLeft = new THREE.Mesh(new THREE.BoxGeometry(0.12, 1.3, 1.9), caseMat);
    sideLeft.position.set(-1.16, 0.05, 0);
    skinGroup.add(sideLeft);
    const sideRight = new THREE.Mesh(new THREE.BoxGeometry(0.12, 1.3, 1.9), caseMat);
    sideRight.position.set(1.16, 0.05, 0);
    skinGroup.add(sideRight);
    const topCase = new THREE.Mesh(new THREE.BoxGeometry(2.1, 0.1, 1.9), caseMat);
    topCase.position.set(0, 0.75, 0);
    skinGroup.add(topCase);
    const frontBezel = new THREE.Mesh(new THREE.BoxGeometry(2.2, 1.2, 0.05), caseMat);
    frontBezel.position.set(0, 0, 1.05);
    skinGroup.add(frontBezel);

    // ---- MOTHERBOARD with circuit traces ----
    const boardBase = new THREE.Mesh(new THREE.BoxGeometry(1.9, 0.1, 1.6),
      createClippedMaterial(0x0d2e0d, { roughness: 0.8, metalness: 0.1 }));
    boardBase.position.set(0, -0.35, -0.1);
    boardGroup.add(boardBase);

    // Copper traces (many thin lines)
    const traceMat = new THREE.LineBasicMaterial({ color: 0xd4af37, clippingPlanes: clipPlanes });
    const tracePoints = [];
    for (let i = 0; i < 40; i++) {
      const x1 = (Math.random() - 0.5) * 1.7;
      const z1 = (Math.random() - 0.5) * 1.4 - 0.1;
      const x2 = x1 + (Math.random() - 0.5) * 0.5;
      const z2 = z1 + (Math.random() - 0.5) * 0.5;
      const y = -0.29;
      const geom = new THREE.BufferGeometry().setFromPoints([
        new THREE.Vector3(x1, y, z1), new THREE.Vector3(x2, y, z2)
      ]);
      boardGroup.add(new THREE.Line(geom, traceMat));
    }

    // ---- DETAILED COMPONENTS ----
    // CPU socket with pins
    const cpuSocket = new THREE.Mesh(new THREE.BoxGeometry(0.55, 0.1, 0.55),
      createClippedMaterial(0x888888, { roughness: 0.3, metalness: 0.9 }));
    cpuSocket.position.set(0, -0.28, 0.2);
    componentsGroup.add(cpuSocket);
    // Pins (small cylinders)
    for (let xi = -0.2; xi <= 0.2; xi += 0.1) {
      for (let zi = 0.0; zi <= 0.4; zi += 0.1) {
        const pin = new THREE.Mesh(new THREE.CylinderGeometry(0.02, 0.02, 0.07, 6),
          createClippedMaterial(0xffd700, { roughness: 0.1, metalness: 1 }));
        pin.position.set(xi, -0.24, 0.2 + zi - 0.2);
        componentsGroup.add(pin);
      }
    }
    const cpuChip = new THREE.Mesh(new THREE.BoxGeometry(0.45, 0.08, 0.45),
      createClippedMaterial(0x1a1a3a, { roughness: 0.1, metalness: 0.9, emissive: new THREE.Color(0x000022) }));
    cpuChip.position.set(0, -0.21, 0.2);
    cpuChip.userData = { component: 'cpu' };
    componentsGroup.add(cpuChip);

    // GPU
    const gpuBoard = new THREE.Mesh(new THREE.BoxGeometry(0.7, 0.08, 1.1),
      createClippedMaterial(0x2a2a40, { roughness: 0.4, metalness: 0.8 }));
    gpuBoard.position.set(0.5, -0.5, -0.1);
    gpuBoard.userData = { component: 'gpu' };
    componentsGroup.add(gpuBoard);
    // GPU fan
    const fan = new THREE.Mesh(new THREE.CylinderGeometry(0.25, 0.25, 0.08, 16),
      createClippedMaterial(0x333344, { roughness: 0.3, metalness: 0.7 }));
    fan.position.set(0.5, -0.42, -0.1);
    componentsGroup.add(fan);

    // RAM sticks with chips
    for (let i = -0.6; i <= 0.6; i+=1.2) {
      const stick = new THREE.Mesh(new THREE.BoxGeometry(0.16, 0.3, 0.06),
        createClippedMaterial(0x2e6b2e, { roughness: 0.5 }));
      stick.position.set(i, -0.12, 0.68);
      stick.userData = { component: 'ram', index: i };
      componentsGroup.add(stick);
      // RAM chips on stick
      for (let j = -0.1; j <= 0.1; j+=0.1) {
        const chip = new THREE.Mesh(new THREE.BoxGeometry(0.04, 0.06, 0.04),
          createClippedMaterial(0x111111, { roughness: 0.2 }));
        chip.position.set(i, -0.12 + j, 0.71);
        componentsGroup.add(chip);
      }
    }

    // Chipset (southbridge)
    const chipset = new THREE.Mesh(new THREE.BoxGeometry(0.4, 0.08, 0.4),
      createClippedMaterial(0x444466, { roughness: 0.3, metalness: 0.6 }));
    chipset.position.set(-0.5, -0.45, -0.4);
    chipset.userData = { component: 'chipset' };
    componentsGroup.add(chipset);

    // Capacitors
    for (let k = 0; k < 8; k++) {
      const cap = new THREE.Mesh(new THREE.CylinderGeometry(0.06, 0.06, 0.15, 8),
        createClippedMaterial(0x222222, { roughness: 0.2 }));
      cap.position.set(-0.7 + k * 0.2, -0.28, -0.7);
      componentsGroup.add(cap);
    }

    // ---- LABELS ----
    function makeLabel(text, pos, color='#fff') {
      const div = document.createElement('div');
      div.textContent = text;
      div.style.color = color;
      div.style.fontSize = '12px';
      div.style.fontWeight = 'bold';
      div.style.background = 'rgba(0,0,0,0.7)';
      div.style.padding = '2px 8px';
      div.style.borderRadius = '4px';
      const lbl = new CSS2DObject(div);
      lbl.position.copy(pos);
      return lbl;
    }
    const labelGroup = new THREE.Group();
    labelGroup.add(makeLabel('CPU', new THREE.Vector3(0, 0.0, 0.2), '#aaccff'));
    labelGroup.add(makeLabel('GPU', new THREE.Vector3(0.5, -0.3, -0.1), '#ccaa88'));
    labelGroup.add(makeLabel('RAM', new THREE.Vector3(-0.6, 0.1, 0.75), '#88cc88'));
    labelGroup.add(makeLabel('Chipset', new THREE.Vector3(-0.5, -0.3, -0.4), '#cc88cc'));
    componentsGroup.add(labelGroup);

    // ---- CLIP PLANE VISUALIZATION (optional) ----
    const clipPlaneHelper = new THREE.PlaneHelper(clippingPlane, 2, 0xff0000);
    clipPlaneHelper.visible = false;
    scene.add(clipPlaneHelper);

    // ---- DATA FLOW PACKET (for simulation) ----
    const packet = new THREE.Mesh(new THREE.SphereGeometry(0.06, 12, 12),
      new THREE.MeshBasicMaterial({ color: 0x44aaff }));
    packet.visible = false;
    scene.add(packet);

    // ---- UI STATE ----
    const opacitySlider = document.getElementById('opacity-slider');
    const opacityVal = document.getElementById('opacity-val');
    caseMat.opacity = 0.9;
    opacitySlider.addEventListener('input', () => {
      const val = parseInt(opacitySlider.value) / 100;
      caseMat.opacity = val;
      opacityVal.textContent = Math.round(val*100) + '%';
    });

    const clipToggle = document.getElementById('clip-toggle');
    const clipSlider = document.getElementById('clip-slider');
    let clippingActive = false;
    clipToggle.addEventListener('click', () => {
      clippingActive = !clippingActive;
      clipToggle.textContent = clippingActive ? '🧠 Clip Plane ON' : '🧠 Clip Plane OFF';
      clipToggle.classList.toggle('active', clippingActive);
      clipSlider.disabled = !clippingActive;
      clipPlaneHelper.visible = clippingActive;
      if (!clippingActive) {
        clippingPlane.constant = 0;
        clipSlider.value = 0;
      }
    });
    clipSlider.addEventListener('input', () => {
      clippingPlane.constant = parseFloat(clipSlider.value);
    });

    document.getElementById('reset-view').addEventListener('click', () => {
      camera.position.set(5, 3.5, 7);
      controls.target.set(0, 0.15, 0);
      controls.update();
    });

    // ---- INSPECTION PANEL LOGIC ----
    const inspectPanel = document.getElementById('inspect-panel');
    const partName = document.getElementById('part-name');
    const blockCanvas = document.getElementById('block-diagram');
    const codeSnippet = document.getElementById('code-snippet');
    const simulateBtn = document.getElementById('simulate-btn');
    const closePanel = document.getElementById('close-panel');
    let selectedComponent = null;

    closePanel.addEventListener('click', () => {
      inspectPanel.style.display = 'none';
      selectedComponent = null;
    });

    // Draw block diagram on canvas for each component
    function drawBlockDiagram(type) {
      const ctx = blockCanvas.getContext('2d');
      ctx.clearRect(0, 0, blockCanvas.width, blockCanvas.height);
      ctx.fillStyle = '#1a1a2e';
      ctx.fillRect(0, 0, blockCanvas.width, blockCanvas.height);
      ctx.strokeStyle = '#4a90e2';
      ctx.fillStyle = '#ffffff';
      ctx.font = '12px sans-serif';
      if (type === 'cpu') {
        ctx.fillText('Fetch → Decode → Execute → Writeback', 20, 40);
        ctx.strokeRect(15, 20, 60, 30);
        ctx.strokeRect(85, 20, 60, 30);
        ctx.strokeRect(155, 20, 70, 30);
        ctx.strokeRect(235, 20, 75, 30);
        ctx.fillText('ALU', 180, 80);
      } else if (type === 'gpu') {
        ctx.fillText('Shader Cores (16)', 20, 30);
        ctx.fillText('TMU  |  ROP', 20, 60);
        ctx.strokeRect(10, 40, 140, 30);
      } else if (type === 'ram') {
        for (let r = 0; r < 4; r++) {
          for (let c = 0; c < 8; c++) {
            ctx.strokeRect(10 + c*25, 30 + r*20, 20, 15);
          }
        }
        ctx.fillText('DRAM Cell Array', 20, 110);
      } else if (type === 'chipset') {
        ctx.fillText('PCIe Bridge | USB | SATA', 20, 40);
        ctx.strokeRect(10, 25, 280, 30);
      }
    }

    function setCodeSnippet(type) {
      if (type === 'cpu') {
        codeSnippet.innerHTML = `<span class="highlight">ADD R0, R1</span>  ; currently executing<br>MOV R2, R0<br>STORE R2, [0xFF]`;
      } else if (type === 'gpu') {
        codeSnippet.innerHTML = `gl_Position = uMVPMatrix * vec4(aPosition,1.0);<br>fragColor = texture(uSampler, vTexCoord);`;
      } else if (type === 'ram') {
        codeSnippet.innerHTML = `int* ptr = malloc(64);<br>ptr[0] = 5;  // stored at 0x1000`;
      } else if (type === 'chipset') {
        codeSnippet.innerHTML = `// DMA transfer from disk to RAM<br>memcpy(buf, disk_sector, 512);`;
      }
    }

    // Animate data flow
    let animId = null;
    function animatePacketPath(positions, callback) {
      if (animId) cancelAnimationFrame(animId);
      packet.visible = true;
      let idx = 0;
      const duration = 600;
      function step() {
        if (idx >= positions.length - 1) {
          packet.visible = false;
          if (callback) callback();
          return;
        }
        const start = positions[idx];
        const end = positions[idx+1];
        const startTime = performance.now();
        function tick(now) {
          const t = Math.min((now - startTime) / duration, 1.0);
          packet.position.lerpVectors(start, end, t);
          if (t < 1) {
            animId = requestAnimationFrame(tick);
          } else {
            idx++;
            step();
          }
        }
        animId = requestAnimationFrame(tick);
      }
      step();
    }

    simulateBtn.addEventListener('click', () => {
      if (!selectedComponent) return;
      const type = selectedComponent.userData.component;
      const cpuPos = new THREE.Vector3(0, -0.15, 0.2);
      const ramPos = new THREE.Vector3(-0.6, -0.05, 0.7);
      const gpuPos = new THREE.Vector3(0.5, -0.4, -0.1);
      const chipPos = new THREE.Vector3(-0.5, -0.4, -0.4);
      let path = [];
      if (type === 'cpu') {
        path = [ramPos, cpuPos, ramPos];
      } else if (type === 'gpu') {
        path = [cpuPos, gpuPos, cpuPos];
      } else if (type === 'ram') {
        path = [cpuPos, ramPos, cpuPos];
      } else if (type === 'chipset') {
        path = [chipPos, cpuPos, chipPos];
      }
      animatePacketPath(path);
    });

    // ---- RAYCASTER FOR CLICK ---- 
    const raycaster = new THREE.Raycaster();
    const mouse = new THREE.Vector2();
    renderer.domElement.addEventListener('click', (e) => {
      mouse.x = (e.clientX / window.innerWidth) * 2 - 1;
      mouse.y = -(e.clientY / window.innerHeight) * 2 + 1;
      raycaster.setFromCamera(mouse, camera);
      const intersects = raycaster.intersectObjects(componentsGroup.children, true);
      if (intersects.length > 0) {
        let obj = intersects[0].object;
        while (obj && !obj.userData.component) obj = obj.parent;
        if (obj && obj.userData.component) {
          selectedComponent = obj;
          const comp = obj.userData.component;
          partName.textContent = comp.toUpperCase();
          drawBlockDiagram(comp);
          setCodeSnippet(comp);
          inspectPanel.style.display = 'flex';
        }
      }
    });

    // ---- ANIMATION LOOP ----
    function animate() {
      requestAnimationFrame(animate);
      controls.update();
      renderer.render(scene, camera);
      labelRenderer.render(scene, camera);
    }
    animate();

    window.addEventListener('resize', () => {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
      labelRenderer.setSize(window.innerWidth, window.innerHeight);
    });

    console.log('Surgeon-level PC inspector ready. Adjust case opacity, toggle clip plane, click components.');
  </script>
</body>
</html>
