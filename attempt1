<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
  <title>Layered Computer – Skin, Framework, Metaphysical</title>
  <style>
    body {
      margin: 0;
      overflow: hidden;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
    #navbar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      background: rgba(10, 10, 20, 0.9);
      backdrop-filter: blur(10px);
      display: flex;
      justify-content: center;
      gap: 1.5rem;
      padding: 0.8rem 1.5rem;
      z-index: 10;
      border-bottom: 1px solid rgba(255, 255, 255, 0.15);
      box-shadow: 0 4px 20px rgba(0,0,0,0.5);
    }
    .nav-btn {
      background: transparent;
      border: 1px solid rgba(255,255,255,0.3);
      color: #ccc;
      padding: 0.6rem 1.8rem;
      border-radius: 30px;
      font-size: 1rem;
      font-weight: 500;
      letter-spacing: 0.5px;
      cursor: pointer;
      transition: all 0.3s ease;
      text-transform: uppercase;
    }
    .nav-btn:hover {
      background: rgba(255,255,255,0.1);
      border-color: #fff;
      color: #fff;
    }
    .nav-btn.active {
      background: #4a90e2;
      border-color: #4a90e2;
      color: white;
      box-shadow: 0 0 15px #4a90e2aa;
    }
    #info-panel {
      position: fixed;
      bottom: 30px;
      left: 30px;
      background: rgba(0,0,0,0.75);
      backdrop-filter: blur(8px);
      color: #eee;
      padding: 1rem 1.5rem;
      border-radius: 12px;
      max-width: 320px;
      font-size: 0.9rem;
      line-height: 1.5;
      border-left: 4px solid #4a90e2;
      transition: opacity 0.3s;
    }
    @media (max-width: 700px) {
      #navbar {
        gap: 0.8rem;
        padding: 0.5rem 1rem;
        flex-wrap: wrap;
      }
      .nav-btn {
        padding: 0.4rem 1.2rem;
        font-size: 0.8rem;
      }
    }
  </style>
</head>
<body>
  <div id="navbar">
    <button id="btn-skin" class="nav-btn active">Skin</button>
    <button id="btn-framework" class="nav-btn">Framework</button>
    <button id="btn-metaphysical" class="nav-btn">Metaphysical (Code)</button>
    <button id="btn-overview" class="nav-btn">System Overview</button>
  </div>
  <div id="info-panel">
    <strong>Skin (Case)</strong><br>
    The outer enclosure – protects and houses all components. Rotate the view.
  </div>

  <!-- Three.js -->
  <script type="importmap">
    {
      "imports": {
        "three": "https://unpkg.com/three@0.152.0/build/three.module.js",
        "three/addons/": "https://unpkg.com/three@0.152.0/examples/jsm/"
      }
    }
  </script>

  <script type="module">
    import * as THREE from 'three';
    import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
    import { CSS2DRenderer, CSS2DObject } from 'three/addons/renderers/CSS2DRenderer.js';

    // --- Initialize scene, camera, renderers ---
    const scene = new THREE.Scene();
    scene.background = new THREE.Color(0x0a0a14);
    scene.fog = new THREE.Fog(0x0a0a14, 5, 25);

    const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.5, 50);
    camera.position.set(6, 4, 8);
    camera.lookAt(0, 0, 0);

    // WebGL renderer
    const renderer = new THREE.WebGLRenderer({ antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.shadowMap.enabled = true;
    renderer.shadowMap.type = THREE.PCFSoftShadowMap;
    document.body.appendChild(renderer.domElement);

    // CSS2 renderer for labels
    const labelRenderer = new CSS2DRenderer();
    labelRenderer.setSize(window.innerWidth, window.innerHeight);
    labelRenderer.domElement.style.position = 'absolute';
    labelRenderer.domElement.style.top = '0px';
    labelRenderer.domElement.style.left = '0px';
    labelRenderer.domElement.style.pointerEvents = 'none'; // allow clicking through to WebGL
    document.body.appendChild(labelRenderer.domElement);

    // Controls
    const controls = new OrbitControls(camera, renderer.domElement);
    controls.enableDamping = true;
    controls.dampingFactor = 0.05;
    controls.target.set(0, 0.2, 0);
    controls.update();

    // --- Lighting ---
    const ambientLight = new THREE.AmbientLight(0x404066);
    scene.add(ambientLight);
    const dirLight = new THREE.DirectionalLight(0xffffff, 1.2);
    dirLight.position.set(5, 8, 5);
    dirLight.castShadow = true;
    dirLight.receiveShadow = true;
    dirLight.shadow.mapSize.width = 1024;
    dirLight.shadow.mapSize.height = 1024;
    dirLight.shadow.camera.near = 1;
    dirLight.shadow.camera.far = 30;
    dirLight.shadow.camera.left = -8;
    dirLight.shadow.camera.right = 8;
    dirLight.shadow.camera.top = 8;
    dirLight.shadow.camera.bottom = -5;
    scene.add(dirLight);
    
    const fillLight = new THREE.PointLight(0x335577, 0.8);
    fillLight.position.set(-3, 1, 3);
    scene.add(fillLight);

    // --- Groups for layered visibility ---
    const skinGroup = new THREE.Group();      // Case panels
    const frameworkGroup = new THREE.Group(); // Motherboard, CPU, GPU, RAM
    const metaGroup = new THREE.Group();      // Code flow (particles/lines)
    const allComponents = new THREE.Group();  // Static base that always visible? We'll keep base chassis visible.
    
    scene.add(skinGroup);
    scene.add(frameworkGroup);
    scene.add(metaGroup);
    scene.add(allComponents);

    // --- Build the computer model ---
    
    // Base inner chassis (always visible, acts as frame)
    const chassisMat = new THREE.MeshStandardMaterial({ color: 0x2a2a3a, roughness: 0.6, metalness: 0.4 });
    const chassis = new THREE.Mesh(new THREE.BoxGeometry(2.2, 1.4, 2.0), chassisMat);
    chassis.position.y = 0;
    chassis.castShadow = true;
    chassis.receiveShadow = true;
    allComponents.add(chassis);
    
    // Decorative front panel mesh
    const frontPanel = new THREE.Mesh(new THREE.BoxGeometry(2.2, 1.2, 0.1), 
      new THREE.MeshStandardMaterial({ color: 0x1e1e2e, roughness: 0.3, metalness: 0.7 }));
    frontPanel.position.set(0, 0, 1.0);
    allComponents.add(frontPanel);

    // --- SKIN (removable case panels) ---
    const panelMat = new THREE.MeshStandardMaterial({ 
      color: 0x3a3a4a, 
      roughness: 0.25, 
      metalness: 0.8,
      transparent: true,
      opacity: 0.9
    });
    
    // Left side panel
    const leftPanel = new THREE.Mesh(new THREE.BoxGeometry(0.1, 1.3, 1.9), panelMat);
    leftPanel.position.set(-1.15, 0.05, 0);
    leftPanel.castShadow = true;
    leftPanel.receiveShadow = true;
    skinGroup.add(leftPanel);
    
    // Right side panel
    const rightPanel = new THREE.Mesh(new THREE.BoxGeometry(0.1, 1.3, 1.9), panelMat);
    rightPanel.position.set(1.15, 0.05, 0);
    rightPanel.castShadow = true;
    rightPanel.receiveShadow = true;
    skinGroup.add(rightPanel);
    
    // Top panel
    const topPanel = new THREE.Mesh(new THREE.BoxGeometry(2.1, 0.1, 1.9), panelMat);
    topPanel.position.set(0, 0.75, 0);
    topPanel.castShadow = true;
    topPanel.receiveShadow = true;
    skinGroup.add(topPanel);
    
    // Front decorative cover (blends with skin)
    const frontCover = new THREE.Mesh(new THREE.BoxGeometry(2.2, 1.2, 0.05), 
      new THREE.MeshStandardMaterial({ color: 0x4a4a5a, roughness: 0.2, metalness: 0.9 }));
    frontCover.position.set(0, 0, 1.05);
    skinGroup.add(frontCover);

    // --- FRAMEWORK (motherboard and core components) ---
    const boardMat = new THREE.MeshStandardMaterial({ color: 0x1a472a, roughness: 0.7, metalness: 0.2 });
    const motherboard = new THREE.Mesh(new THREE.BoxGeometry(1.9, 0.08, 1.6), boardMat);
    motherboard.position.set(0, -0.3, -0.1);
    motherboard.castShadow = true;
    motherboard.receiveShadow = true;
    frameworkGroup.add(motherboard);
    
    // CPU (central)
    const cpuMat = new THREE.MeshStandardMaterial({ color: 0xc0c0e0, roughness: 0.2, metalness: 0.9, emissive: new THREE.Color(0x111133) });
    const cpu = new THREE.Mesh(new THREE.BoxGeometry(0.5, 0.15, 0.5), cpuMat);
    cpu.position.set(0, -0.2, 0.2);
    cpu.castShadow = true;
    cpu.receiveShadow = true;
    frameworkGroup.add(cpu);
    
    // GPU (larger card)
    const gpuMat = new THREE.MeshStandardMaterial({ color: 0x2a2a40, roughness: 0.3, metalness: 0.8 });
    const gpu = new THREE.Mesh(new THREE.BoxGeometry(0.7, 0.1, 1.1), gpuMat);
    gpu.position.set(0.5, -0.45, -0.1);
    gpu.rotation.x = -0.1;
    gpu.castShadow = true;
    gpu.receiveShadow = true;
    frameworkGroup.add(gpu);
    
    // RAM sticks
    const ramMat = new THREE.MeshStandardMaterial({ color: 0x2e6b2e, roughness: 0.5, metalness: 0.3 });
    for (let i = -0.6; i <= 0.6; i+=1.2) {
      const ram = new THREE.Mesh(new THREE.BoxGeometry(0.15, 0.25, 0.06), ramMat);
      ram.position.set(i, -0.15, 0.65);
      ram.castShadow = true;
      ram.receiveShadow = true;
      frameworkGroup.add(ram);
    }
    
    // CPU cooler (heatsink)
    const coolerMat = new THREE.MeshStandardMaterial({ color: 0x888899, roughness: 0.4, metalness: 0.7 });
    const cooler = new THREE.Mesh(new THREE.BoxGeometry(0.55, 0.25, 0.55), coolerMat);
    cooler.position.set(0, -0.05, 0.2);
    cooler.castShadow = true;
    cooler.receiveShadow = true;
    frameworkGroup.add(cooler);
    
    // --- LABELS (CSS2D) ---
    function createLabel(text, position, color = '#ffffff') {
      const div = document.createElement('div');
      div.textContent = text;
      div.style.color = color;
      div.style.fontWeight = 'bold';
      div.style.fontSize = '14px';
      div.style.textShadow = '1px 1px 3px black';
      div.style.background = 'rgba(20,20,30,0.8)';
      div.style.padding = '2px 10px';
      div.style.borderRadius = '4px';
      const label = new CSS2DObject(div);
      label.position.copy(position);
      return label;
    }
    
    const labelGroup = new THREE.Group();
    labelGroup.add(createLabel('CPU', new THREE.Vector3(0, 0.15, 0.2), '#aaccff'));
    labelGroup.add(createLabel('GPU', new THREE.Vector3(0.5, -0.25, -0.1), '#ccaa88'));
    labelGroup.add(createLabel('RAM', new THREE.Vector3(-0.6, 0.05, 0.7), '#88cc88'));
    frameworkGroup.add(labelGroup);
    
    // --- METAPHYSICAL LAYER (abstract code flow) ---
    const particleCount = 400;
    const particlesGeo = new THREE.BufferGeometry();
    const particlesPos = new Float32Array(particleCount * 3);
    for (let i = 0; i < particleCount * 3; i += 3) {
      // Spread around CPU area and RAM
      const angle = Math.random() * Math.PI * 2;
      const radius = 0.4 + Math.random() * 0.7;
      particlesPos[i] = Math.cos(angle) * radius;
      particlesPos[i+1] = (Math.random() - 0.5) * 0.8 + 0.1;
      particlesPos[i+2] = Math.sin(angle) * radius + 0.3;
    }
    particlesGeo.setAttribute('position', new THREE.BufferAttribute(particlesPos, 3));
    const particlesMat = new THREE.PointsMaterial({ 
      color: 0x44aaff, 
      size: 0.03,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
      transparent: true
    });
    const codeParticles = new THREE.Points(particlesGeo, particlesMat);
    metaGroup.add(codeParticles);
    
    // Flowing lines (abstract buses)
    const linesMat = new THREE.LineBasicMaterial({ color: 0x3399ff, transparent: true, opacity: 0.4 });
    const linesGroup = new THREE.Group();
    const linePoints = [
      [new THREE.Vector3(-0.6, 0.05, 0.65), new THREE.Vector3(0, -0.05, 0.3)],
      [new THREE.Vector3(0.6, 0.05, 0.65), new THREE.Vector3(0, -0.05, 0.3)],
      [new THREE.Vector3(0, -0.05, 0.3), new THREE.Vector3(0.5, -0.3, -0.1)]
    ];
    linePoints.forEach(([start, end]) => {
      const geo = new THREE.BufferGeometry().setFromPoints([start, end]);
      const line = new THREE.Line(geo, linesMat);
      linesGroup.add(line);
    });
    metaGroup.add(linesGroup);
    
    // A glowing sphere at CPU to represent "execution"
    const execSphere = new THREE.Mesh(
      new THREE.SphereGeometry(0.1, 16, 16),
      new THREE.MeshBasicMaterial({ color: 0x44aaff, transparent: true, opacity: 0.8, blending: THREE.AdditiveBlending })
    );
    execSphere.position.set(0, 0.0, 0.25);
    metaGroup.add(execSphere);

    // --- State management for visibility ---
    function setLayer(layer) {
      // Reset all
      skinGroup.visible = false;
      frameworkGroup.visible = false;
      metaGroup.visible = false;
      
      // Update active button
      document.querySelectorAll('.nav-btn').forEach(btn => btn.classList.remove('active'));
      const infoPanel = document.getElementById('info-panel');
      
      switch(layer) {
        case 'skin':
          skinGroup.visible = true;
          document.getElementById('btn-skin').classList.add('active');
          infoPanel.innerHTML = `<strong>Skin (Case)</strong><br>The outer enclosure protects internal components. Made of metal/plastic, it directs airflow and provides physical structure.`;
          // Camera to case overview
          animateCamera(new THREE.Vector3(4, 2.5, 5), new THREE.Vector3(0, 0.1, 0));
          break;
        case 'framework':
          skinGroup.visible = false; // hide case panels
          frameworkGroup.visible = true;
          document.getElementById('btn-framework').classList.add('active');
          infoPanel.innerHTML = `<strong>Framework</strong><br>Motherboard (PCB) connects CPU, GPU, RAM. The physical "skeleton" where data travels via copper traces.`;
          animateCamera(new THREE.Vector3(1.5, 1.8, 2.8), new THREE.Vector3(0, -0.2, 0.2));
          break;
        case 'metaphysical':
          frameworkGroup.visible = true; // show hardware underneath
          metaGroup.visible = true;
          document.getElementById('btn-metaphysical').classList.add('active');
          infoPanel.innerHTML = `<strong>Metaphysical (Code Layer)</strong><br>Software is a pattern of electrical states. The CPU fetches instructions from RAM, decodes, executes. This separation allows infinite software on one machine.`;
          animateCamera(new THREE.Vector3(0.4, 0.7, 1.6), new THREE.Vector3(0, -0.1, 0.3));
          break;
        case 'overview':
          skinGroup.visible = true;
          frameworkGroup.visible = true;
          metaGroup.visible = true;
          document.getElementById('btn-overview').classList.add('active');
          infoPanel.innerHTML = `<strong>Whole System Unit</strong><br>Hardware (skin + framework) and software (metaphysical) united. The device transforms code into action through interconnected components.`;
          animateCamera(new THREE.Vector3(5, 3.5, 6), new THREE.Vector3(0, 0.2, 0));
          break;
      }
    }
    
    function animateCamera(targetPos, targetLook) {
      const startPos = camera.position.clone();
      const startTarget = controls.target.clone();
      const duration = 800;
      const startTime = performance.now();
      
      function update() {
        const now = performance.now();
        const elapsed = now - startTime;
        const t = Math.min(elapsed / duration, 1.0);
        // ease in-out
        const ease = t < 0.5 ? 2*t*t : -1+(4-2*t)*t;
        camera.position.lerpVectors(startPos, targetPos, ease);
        controls.target.lerpVectors(startTarget, targetLook, ease);
        controls.update();
        if (t < 1) {
          requestAnimationFrame(update);
        }
      }
      update();
    }

    // --- Event listeners for navbar ---
    document.getElementById('btn-skin').addEventListener('click', () => setLayer('skin'));
    document.getElementById('btn-framework').addEventListener('click', () => setLayer('framework'));
    document.getElementById('btn-metaphysical').addEventListener('click', () => setLayer('metaphysical'));
    document.getElementById('btn-overview').addEventListener('click', () => setLayer('overview'));

    // Initial state
    setLayer('skin');

    // --- Animation loop ---
    function animate() {
      requestAnimationFrame(animate);
      
      // Rotate code particles slightly for dynamism
      if (metaGroup.visible) {
        codeParticles.rotation.y += 0.002;
        linesGroup.rotation.y += 0.001;
      }
      
      controls.update();
      
      // Render
      renderer.render(scene, camera);
      labelRenderer.render(scene, camera);
    }
    
    animate();

    // Handle window resize
    window.addEventListener('resize', () => {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
      labelRenderer.setSize(window.innerWidth, window.innerHeight);
    });

    console.log('Layered Computer environment ready. Use navbar to explore Skin → Framework → Metaphysical → Overview.');
  </script>
</body>
</html>
